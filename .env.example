# Sesiones del QR representante (Vercel / varias instancias). Elija UNA opción:
#
# Opción A — API REST (pestaña "REST API" en Upstash; URL empieza por https://)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXX...
# (Integración Vercel KV: KV_REST_API_URL + KV_REST_API_TOKEN)
#
# Opción B — Misma URL que para redis-cli --tls (redis://… NO es la URL REST)
# REDIS_URL=redis://default:CONTRASEÑA@nombre.upstash.io:6379
