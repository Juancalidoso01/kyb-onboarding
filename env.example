# Copiar a .env.local:
#   cp env.example .env.local
#
# URL del backend FastAPI (desarrollo)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# --- Geoapify (autocompletado de direcciones, Panamá) ---
# 1) Cree cuenta en https://www.geoapify.com/ → My projects → API keys.
# 2) Copie la API key (no hay usuario/contraseña aparte en el código).
#
# Recomendado: clave solo en servidor (no viaja al navegador).
GEOAPIFY_API_KEY=
#
# Opcional (solo si no usa el proxy): la clave queda visible en el bundle del cliente.
# NEXT_PUBLIC_GEOAPIFY_API_KEY=

# --- MetaMap (KYC director / representante en paso Declaración) ---
# Web Button + flow en dashboard.getmati.com (checkout-demo).
# Si se omiten, el formulario usa client id / flow id por defecto del proyecto.
# No ponga el client secret aquí (solo entre servidor y MetaMap si usa API OAuth).
NEXT_PUBLIC_METAMAP_CLIENT_ID=
NEXT_PUBLIC_METAMAP_FLOW_ID=

# --- Google Sheets + Drive (registro al finalizar KYB en escritorio) ---
# 1) Cloud Console: habilite Sheets API y Drive API; cree cuenta de servicio y descargue JSON.
# 2) Comparta el Sheet y la carpeta de Drive con el email …@….iam.gserviceaccount.com (Editor).
#    Diagnóstico (GET, sin secretos): /api/kyb/google/submission
# 3) En la fila 1 del Sheet ponga encabezados (mismo orden que inserta la app):
#    fecha_iso | numero_formulario | razon_social | correo | enlace_pdf | director_declara | fecha_declaracion | ref_verificacion | archivos_adjuntos | datos_json | enlaces_drive_completos
#    La última columna incluye enlace a la carpeta del expediente, PDF resumen y cada adjunto (cédulas, factura, etc.) subido desde el formulario.
# 4) GOOGLE_SHEET_TAB = nombre exacto de la pestaña (por defecto en español suele ser "Hoja 1").
#
# Una de estas formas de credencial:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # una línea; en private_key use \n
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=   # base64 del JSON completo (recomendado en Vercel)
# GOOGLE_CLIENT_EMAIL=   GOOGLE_PRIVATE_KEY=   # alternativa; la clave PEM con \n escapados
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_TAB=Hoja 1
